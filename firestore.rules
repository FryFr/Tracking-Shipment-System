rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {

    // Authenticated Dynapro users can create/update their own session records
    match /usage_sessions/{sessionId} {
      allow create: if request.auth != null
        && request.resource.data.email == request.auth.token.email;
      allow update: if request.auth != null
        && resource.data.email == request.auth.token.email;
      allow read: if request.auth != null;
    }

    // Authenticated users can submit feedback (write-only for privacy)
    match /feedback/{feedbackId} {
      allow create: if request.auth != null
        && request.resource.data.email == request.auth.token.email;
    }

    // Logistics ETA annotations — authenticated Dynapro users can read/write
    match /logistics_eta/{trackingNumber} {
      allow read, write: if request.auth != null;
    }

    // Order-tracking associations — maps order refs (SO/PO/OC) to tracking numbers
    match /order_trackings/{orderId} {
      allow read, write: if request.auth != null;
    }

    // Tracking metadata — stores order references linked from the web app
    match /tracking_metadata/{trackingNumber} {
      allow read, write: if request.auth != null;
    }

    // Deny everything else by default (no wildcard open access)
  }
}
